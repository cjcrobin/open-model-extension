{
  "name": "open-model",
  "displayName": "Open Model — Kimi, DeepSeek, GLM & Qwen for Copilot Chat",
  "description": "Use Kimi (Moonshot AI), DeepSeek V4, GLM-5, and Qwen3 models directly in GitHub Copilot Chat. Supports streaming, reasoning tokens (DeepSeek R1, QwQ), and 1M context windows.",
  "version": "0.1.2",
  "publisher": "JingciChen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cjcrobin/open-model-extension.git"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Machine Learning"
  ],
  "keywords": [
    "kimi",
    "moonshot",
    "deepseek",
    "deepseek-v4",
    "deepseek-r1",
    "glm",
    "zhipu",
    "qwen",
    "qwen3",
    "qwq",
    "copilot",
    "copilot chat",
    "ai",
    "llm",
    "language model",
    "reasoning",
    "china ai"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "images/Logo.png",
  "main": "./dist/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      { "vendor": "kimi",     "displayName": "Kimi (Moonshot AI)" },
      { "vendor": "deepseek", "displayName": "DeepSeek" },
      { "vendor": "glm",      "displayName": "GLM (Zhipu AI)" },
      { "vendor": "qwen",     "displayName": "Qwen (Alibaba)" }
    ],
    "configuration": {
      "title": "Open Model for Copilot Chat",
      "properties": {
        "openModel.kimi.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Kimi (Moonshot AI) models in Copilot Chat"
        },
        "openModel.kimi.models": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "description": "Model ID" },
              "name": { "type": "string", "description": "Display name" },
              "maxInputTokens": { "type": "number", "description": "Max input tokens" },
              "maxOutputTokens": { "type": "number", "description": "Max output tokens" }
            },
            "required": ["id", "name"]
          },
          "default": [
            { "id": "kimi-k2.6", "name": "Kimi K2.6", "maxInputTokens": 262144, "maxOutputTokens": 32768 },
            { "id": "kimi-k2.5", "name": "Kimi K2.5", "maxInputTokens": 262144, "maxOutputTokens": 32768 },
            { "id": "moonshot-v1-128k", "name": "Moonshot V1 128K", "maxInputTokens": 131072, "maxOutputTokens": 16384 },
            { "id": "moonshot-v1-32k", "name": "Moonshot V1 32K", "maxInputTokens": 32768, "maxOutputTokens": 16384 },
            { "id": "moonshot-v1-8k", "name": "Moonshot V1 8K", "maxInputTokens": 8192, "maxOutputTokens": 4096 }
          ],
          "description": "List of Kimi models to register. Each model requires id and name."
        },
        "openModel.deepseek.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable DeepSeek models in Copilot Chat"
        },
        "openModel.deepseek.models": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "description": "Model ID" },
              "name": { "type": "string", "description": "Display name" },
              "maxInputTokens": { "type": "number", "description": "Max input tokens" },
              "maxOutputTokens": { "type": "number", "description": "Max output tokens" }
            },
            "required": ["id", "name"]
          },
          "default": [
            { "id": "deepseek-v4-flash", "name": "DeepSeek V4 Flash", "maxInputTokens": 1000000, "maxOutputTokens": 393216 },
            { "id": "deepseek-v4-pro", "name": "DeepSeek V4 Pro", "maxInputTokens": 1000000, "maxOutputTokens": 393216 },
            { "id": "deepseek-chat", "name": "DeepSeek V3 (Legacy)", "maxInputTokens": 65536, "maxOutputTokens": 8192 },
            { "id": "deepseek-reasoner", "name": "DeepSeek R1 (Legacy)", "maxInputTokens": 65536, "maxOutputTokens": 32768 }
          ],
          "description": "List of DeepSeek models to register. Each model requires id and name."
        },
        "openModel.glm.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable GLM (Zhipu AI) models in Copilot Chat"
        },
        "openModel.glm.models": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "description": "Model ID" },
              "name": { "type": "string", "description": "Display name" },
              "maxInputTokens": { "type": "number", "description": "Max input tokens" },
              "maxOutputTokens": { "type": "number", "description": "Max output tokens" }
            },
            "required": ["id", "name"]
          },
          "default": [
            { "id": "glm-5.1", "name": "GLM-5.1", "maxInputTokens": 200000, "maxOutputTokens": 131072 },
            { "id": "glm-5", "name": "GLM-5", "maxInputTokens": 200000, "maxOutputTokens": 131072 },
            { "id": "glm-5-turbo", "name": "GLM-5-Turbo", "maxInputTokens": 200000, "maxOutputTokens": 131072 },
            { "id": "glm-4.7", "name": "GLM-4.7", "maxInputTokens": 200000, "maxOutputTokens": 131072 },
            { "id": "glm-4.7-flash", "name": "GLM-4.7-Flash (Free)", "maxInputTokens": 200000, "maxOutputTokens": 131072 },
            { "id": "glm-4-long", "name": "GLM-4-Long (1M context)", "maxInputTokens": 1000000, "maxOutputTokens": 4096 }
          ],
          "description": "List of GLM models to register. Each model requires id and name."
        },
        "openModel.qwen.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Qwen (Alibaba Cloud) models in Copilot Chat"
        },
        "openModel.qwen.models": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "description": "Model ID" },
              "name": { "type": "string", "description": "Display name" },
              "maxInputTokens": { "type": "number", "description": "Max input tokens" },
              "maxOutputTokens": { "type": "number", "description": "Max output tokens" }
            },
            "required": ["id", "name"]
          },
          "default": [
            { "id": "qwen3.6-plus", "name": "Qwen3.6-Plus", "maxInputTokens": 1000000, "maxOutputTokens": 32768 },
            { "id": "qwen3.6-flash", "name": "Qwen3.6-Flash", "maxInputTokens": 1000000, "maxOutputTokens": 32768 },
            { "id": "qwen3.6-max-preview", "name": "Qwen3.6-Max (Preview)", "maxInputTokens": 262144, "maxOutputTokens": 32768 },
            { "id": "qwen3-235b-a22b", "name": "Qwen3-235B-A22B", "maxInputTokens": 131072, "maxOutputTokens": 32768 },
            { "id": "qwen3-32b", "name": "Qwen3-32B", "maxInputTokens": 131072, "maxOutputTokens": 32768 },
            { "id": "qwq-32b", "name": "QwQ-32B (Reasoning)", "maxInputTokens": 131072, "maxOutputTokens": 32768 }
          ],
          "description": "List of Qwen models to register. Each model requires id and name."
        }
      }
    },
    "commands": [
      {
        "command": "openModel.setApiKey",
        "title": "Open Model: Set API Key",
        "category": "Open Model"
      },
      {
        "command": "openModel.configure",
        "title": "Open Model: Configure Providers",
        "category": "Open Model"
      },
      {
        "command": "openModel.reload",
        "title": "Open Model: Reload Providers",
        "category": "Open Model"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.99.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.5.4",
    "webpack": "^5.94.0",
    "webpack-cli": "^5.1.4"
  }
}
