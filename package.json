        },
        "openModel.doubao.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Doubao (ByteDance) models in Copilot Chat"
        },
        "openModel.doubao.models": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Model ID"
              },
              "name": {
                "type": "string",
                "description": "Display name"
              },
              "maxInputTokens": {
                "type": "number",
                "description": "Max input tokens"
              },
              "maxOutputTokens": {
                "type": "number",
                "description": "Max output tokens"
              },
              "baseUrlOverride": {
                "type": "string",
