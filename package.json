{
  "name": "open-model",
  "displayName": "Open Model — Kimi, DeepSeek, GLM, Qwen & Doubao for Copilot Chat",
  "description": "Use Kimi (Moonshot AI), DeepSeek V4, GLM-5, Qwen3, and Doubao (ByteDance) models directly in GitHub Copilot Chat. Supports streaming, reasoning tokens, vision, and 1M context windows.",
  "version": "0.1.3",
  "publisher": "JingciChen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cjcrobin/open-model-extension.git"
  },
  "engines": {
    "vscode": "^1.99.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Machine Learning"
  ],
  "keywords": [
    "kimi",
    "moonshot",
    "deepseek",
    "deepseek-v4",
    "deepseek-r1",
    "glm",
    "zhipu",
    "qwen",
    "qwen3",
    "qwq",
    "doubao",
    "bytedance",
    "copilot",
    "copilot chat",
    "ai",
    "llm",
    "language model",
    "reasoning",
    "china ai"
  ],
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "images/Logo.png",
  "main": "./dist/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "kimi",
        "displayName": "Kimi (Moonshot AI)"
      },
      {
        "vendor": "deepseek",
        "displayName": "DeepSeek"
      },
      {
        "vendor": "glm",
        "displayName": "GLM (Zhipu AI)"
      },
      {
        "vendor": "qwen",
        "displayName": "Qwen (Alibaba)"
      },
      {
        "vendor": "doubao",
        "displayName": "Doubao (ByteDance)"
      },
      {
        "vendor": "custom",
        "displayName": "Custom (OpenAI Compatible)"
      }
    ],
    "configuration": {
      "title": "Open Model for Copilot Chat",
      "properties": {
        "openModel.kimi.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Kimi (Moonshot AI) models in Copilot Chat"
        },
        "openModel.kimi.models": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Model ID"
              },
              "name": {
                "type": "string",
                "description": "Display name"
              },
              "maxInputTokens": {
                "type": "number",
                "description": "Max input tokens"
              },
              "maxOutputTokens": {
                "type": "number",
                "description": "Max output tokens"
              },
              "baseUrlOverride": {
                "type": "string",
                "description": "Override the default API base URL for this model (e.g. for proxy or self-hosted endpoints)"
              },
              "supportsVision": {
                "type": "boolean",
                "default": false,
                "description": "Whether this model supports image/vision input"
              },
              "supportsReasoning": {
                "type": "boolean",
                "default": false,
                "description": "Whether this model outputs reasoning/thinking tokens (e.g. DeepSeek R1, QwQ)"
              }
            },
            "required": [
              "id",
              "name"
            ]
          },
          "default": [
            {
              "id": "kimi-k2.6",
              "name": "Kimi K2.6",
              "maxInputTokens": 262144,
              "maxOutputTokens": 32768,
              "supportsVision": true
            },
            {
              "id": "kimi-k2.5",
              "name": "Kimi K2.5",
              "maxInputTokens": 262144,
              "maxOutputTokens": 32768,
              "supportsVision": true
            },
            {
              "id": "moonshot-v1-128k",
              "name": "Moonshot V1 128K",
              "maxInputTokens": 131072,
              "maxOutputTokens": 16384
            },
            {
              "id": "moonshot-v1-32k",
              "name": "Moonshot V1 32K",
              "maxInputTokens": 32768,
              "maxOutputTokens": 16384
            },
            {
              "id": "moonshot-v1-8k",
              "name": "Moonshot V1 8K",
              "maxInputTokens": 8192,
              "maxOutputTokens": 4096
            }
          ],
          "description": "List of Kimi models to register. Each model requires id and name."
        },
        "openModel.deepseek.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable DeepSeek models in Copilot Chat"
        },
        "openModel.deepseek.models": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "description": "Model ID"
              },
              "name": {
                "type": "string",
                "description": "Display name"
              },
              "maxInputTokens": {
                "type": "number",
                "description": "Max input tokens"
              },
              "maxOutputTokens": {
                "type": "number",
                "description": "Max output tokens"
              },
              "baseUrlOverride": {
                "type": "string",
                "description": "Override the default API base URL for this model (e.g. for proxy or self-hosted endpoints)"
              },
              "supportsVision": {
                "type": "boolean",
                "default": false,
                "description": "Whether this model supports image/vision input"
              },
              "supportsReasoning": {
                "type": "boolean",
                "default": false,
                "description": "Whether this model outputs reasoning/thinking tokens (e.g. DeepSeek R1, QwQ)"
              }
            },
            "required": [
              "id",
              "name"
            ]
          },
          "default": [
            {
              "id": "deepseek-v4-flash",
              "name": "DeepSeek V4 Flash",
              "maxInputTokens": 1000000,
              "maxOutputTokens": 393216,
              "supportsVision": true
            },
            {
              "id": "deepseek-v4-pro",
              "name": "DeepSeek V4 Pro",
              "maxInputTokens": 1000000,
              "maxOutputTokens": 393216,
              "supportsVision": true
            },
            {
              "id": "deepseek-chat",
              "name": "DeepSeek V3 (Legacy)",
              "maxInputTokens": 65536,
              "maxOutputTokens": 8192
            },
            {
              "id": "deepseek-reasoner",
              "name": "DeepSeek R1 (Legacy)",
              "maxInputTokens": 65536,
              "maxOutputTokens": 32768,
              "supportsReasoning": true
            }
          ],
          "description": "List of DeepSeek models to register. Each model requires id and name."
        },
        "openModel.glm.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable GLM (Zhipu AI) models in Copilot Chat"
        },
        "openModel.glm.models": {
