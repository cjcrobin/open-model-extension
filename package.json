          "description": "List of GLM models to register. Each model requires id and name."
        },
        "openModel.qwen.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable Qwen (Alibaba Cloud) models in Copilot Chat"
        },
        "openModel.qwen.models": {
          "type": "array",
