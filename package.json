            {
              "id": "qwen3-235b-a22b",
              "name": "Qwen3-235B-A22B",
              "maxInputTokens": 131072,
              "maxOutputTokens": 32768
            },
            {
              "id": "qwen3-32b",
              "name": "Qwen3-32B",
              "maxInputTokens": 131072,
              "maxOutputTokens": 32768
            },
            {
              "id": "qwq-32b",
