          "default": [
            {
              "id": "qwen3.6-plus",
              "name": "Qwen3.6-Plus",
              "maxInputTokens": 1000000,
              "maxOutputTokens": 32768,
              "supportsVision": true
            },
            {
              "id": "qwen3.6-flash",
              "name": "Qwen3.6-Flash",
              "maxInputTokens": 1000000,
              "maxOutputTokens": 32768,
