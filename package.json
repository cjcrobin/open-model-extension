              },
              "supportsVision": {
                "type": "boolean",
                "default": false,
                "description": "Whether this model supports image/vision input"
              },
              "supportsReasoning": {
                "type": "boolean",
                "default": false,
                "description": "Whether this model outputs reasoning/thinking tokens"
              }
            },
            "required": ["id", "name"]
          },
          "default": [
            {
              "id": "doubao-pro-32k",
              "name": "Doubao Pro 32K",
              "maxInputTokens": 32768,
              "maxOutputTokens": 4096
            },
            {
              "id": "doubao-pro-128k",
              "name": "Doubao Pro 128K",
              "maxInputTokens": 131072,
